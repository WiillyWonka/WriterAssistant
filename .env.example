# Скопируйте в .env и заполните (docker compose подхватит автоматически)

# Claude (Anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ChatGPT (OpenAI)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Провайдер по умолчанию, если клиент не передаёт provider: anthropic | openai
LLM_PROVIDER=anthropic

# С какого origin разрешать CORS (через запятую при нескольких)
CORS_ORIGINS=http://localhost:3000

# URL API для браузера (должен совпадать с опубликованным портом бэкенда)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Keycloak (браузер)
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080

# OIDC issuer (должен совпадать с claim iss в access token)
KEYCLOAK_ISSUER=http://localhost:8080/realms/writer-assistant

# Внутри Docker: hostname сервиса keycloak (для token/userinfo на сервере Next.js)
KEYCLOAK_INTERNAL_URL=http://keycloak:8080

# JWKS для бэкенда (внутри Docker-сети)
KEYCLOAK_JWKS_URL=http://keycloak:8080/realms/writer-assistant/protocol/openid-connect/certs

# Audience в access token (protocol mapper в Keycloak)
KEYCLOAK_AUDIENCE=writer-assistant-api

# OAuth client (секрет из realm writer-assistant-web)
KEYCLOAK_CLIENT_ID=writer-assistant-web
KEYCLOAK_CLIENT_SECRET=dev-client-secret-change-me

# Auth.js / NextAuth v5 (минимум 32 символа для продакшена)
AUTH_SECRET=dev-auth-secret-change-in-production-min-32-chars!!
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Postgres (при локальном запуске без Docker — свой URL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/writer_assistant
