# Скопируйте в .env и заполните (docker compose подхватит автоматически)

# === СЕРВЕР ===
# Укажите IP или домен сервера для развёртывания
# Для локальной разработки оставьте localhost
SERVER_IP=localhost

# Claude (Anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ChatGPT (OpenAI)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Провайдер по умолчанию, если клиент не передаёт provider: anthropic | openai
LLM_PROVIDER=anthropic

# С какого origin разрешать CORS (через запятую при нескольких)
# Использует SERVER_IP автоматически
CORS_ORIGINS=http://${SERVER_IP}:3000

# URL API для браузера (должен совпадать с опубликованным портом бэкенда)
# Использует SERVER_IP автоматически
NEXT_PUBLIC_API_URL=http://${SERVER_IP}:8000

# URL Keycloak для браузера
# Использует SERVER_IP автоматически
NEXT_PUBLIC_KEYCLOAK_URL=http://${SERVER_IP}:8080

# Realm и Client ID для Keycloak
NEXT_PUBLIC_KEYCLOAK_REALM=writer-assistant
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=writer-assistant-frontend
