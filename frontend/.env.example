# URL бэкенда (браузер ходит сюда с localhost:3000)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Keycloak (браузер)
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080

# OIDC issuer (совпадает с iss в access token)
KEYCLOAK_ISSUER=http://localhost:8080/realms/writer-assistant

# Внутренний URL Keycloak для сервера Next.js (Docker: http://keycloak:8080)
KEYCLOAK_INTERNAL_URL=http://localhost:8080

# Realm (если не writer-assistant)
# KEYCLOAK_REALM=writer-assistant

# OAuth client из импорта реалма
KEYCLOAK_CLIENT_ID=writer-assistant-web
KEYCLOAK_CLIENT_SECRET=dev-client-secret-change-me

# Auth.js / NextAuth v5
AUTH_SECRET=dev-auth-secret-change-in-production-min-32-chars!!
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
